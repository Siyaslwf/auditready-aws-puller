# AuditReady — evidence puller credentials (BYOK: bring your own keys).
# Copy to .env, fill in, then:   set -a; source .env; set +a
# NEVER commit .env. All scripts are read-only against your infrastructure.

# ── AWS (aws-evidence-puller.py) ────────────────────────────────────────────
# Create a dedicated IAM user/role with the AWS-managed policies:
#   SecurityAudit + ViewOnlyAccess   (read-only, audit-scoped)
# Console: IAM → Users → Create user → attach policies → create access key.
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=eu-central-1
# Optional if you use temporary STS credentials:
# AWS_SESSION_TOKEN=...

# ── Vercel (vercel-evidence-puller.py) ──────────────────────────────────────
# Token: vercel.com → Account Settings → Tokens → Create (scope: your team).
VERCEL_TOKEN=...
# Team ID (starts with team_): vercel.com → Team Settings → General.
# Leave unset for a personal account scope.
VERCEL_TEAM_ID=team_...

# ── Supabase (supabase-evidence-puller.py) ──────────────────────────────────
# Direct Postgres connection string (URI tab):
#   Dashboard → Project Settings → Database → Connection string.
# Use the *session* pooler URI or direct connection; the service role password
# is required to read auth.* tables. Example:
#   postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# ── Optional behavior flags ─────────────────────────────────────────────────
# Where dated evidence folders are written (default: ./evidence-output)
# AUDITREADY_OUTPUT_DIR=evidence-output
# Log verbosity: DEBUG | INFO | WARNING (default INFO)
# AUDITREADY_LOG_LEVEL=INFO
# Export full user emails instead of ***@domain (only if your auditor insists)
# AUDITREADY_FULL_EMAILS=0
